# --- Voice playground (playground/) configuration ---
# Copy to .env at the repo root (the launcher calls load_dotenv()).

# LLM key — pick ONE (stays on your machine; used by the in-process agent).
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Speech backend. Resolution order (see playground/harness/api.py):
#   1. SUPERVOICE_URL (explicit) wins.
#   2. else UNPOD_BASE_URL derives the hosted wss://<host> speech service —
#      a fresh clone needs NO local supervoice with this set.
#   3. else falls back to ws://127.0.0.1:9000 (a local supervoice-dev).
#
# Hosted (recommended for a fresh clone — full voice, no local backend):
UNPOD_BASE_URL=api.unpod.ai
#
# Local supervoice dev server instead (requires ../supervoice + `task supervoice-dev`):
# SUPERVOICE_URL=ws://127.0.0.1:9000

# Worker registration key for the in-process AgentRunner.
UNPOD_API_KEY=dev-key

# Optional overrides.
# PLAYGROUND_PORT=9100         # harness/UI port
# AGENT_NAME=flows             # catalog agent to run (see agents/catalog.py)
