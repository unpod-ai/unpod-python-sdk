# One URL for everything - REST, orchestrator, and speech are derived in code.
# Bare host or any URL form. For Unpod's hosted platform:
UNPOD_BASE_URL=api.unpod.ai

UNPOD_API_KEY=sk_...
AGENT_ID=browser-playground

# Your LLM - stays on your machine
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Local playground UI server port (kept off :9000 to avoid clashing with supervoice)
PLAYGROUND_PORT=9100

# Optional override: point at a specific speech service instead of
# wss://<UNPOD_BASE_URL>. Use this for a local supervoice dev server:
# SUPERVOICE_URL=ws://127.0.0.1:9000

# Optional - point at a flow JSON to drive a DialogMachine; omit for plain LLMAgent
FLOW_JSON_PATH=
